# ---------- Java / Maven ----------
backend/target/
backend/.idea/
*.class
*.jar
*.war
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# ---------- Docker / 容器 ----------
docker-data/
pgdata/

# ---------- IDE / 编辑器 ----------
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
*.bak
*.orig
.DS_Store
Thumbs.db

# ---------- 日志 ----------
*.log
logs/

# ---------- 环境变量 ----------
.env
.env.local
.env.*.local

# ---------- 操作系统 ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- 其他 ----------
